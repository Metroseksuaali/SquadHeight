# exporter output (large, regenerated per machine)
output/

# per-run engine/script logs (run_batch_export.bat)
logs/

# local SquadCalc test harness: cloned upstream app + staged heightmap data.
# Keep the small config (Dockerfile, nginx.conf, compose, scripts) tracked.
squadcalc-test/SquadCalc/
squadcalc-test/heightmaps/
squadcalc-test/dist/
squadcalc-test/*_compare.png
squadcalc-test/__pycache__/

# legacy SquadCalc heightmaps used for local validation
heightmap_*_example.json

# python
__pycache__/
*.pyc

# machine-specific paths
settings.bat

# generated per SDK version - regenerate with tools/make_config.py
tools/maps_config.json

# local tool state
.claude/
